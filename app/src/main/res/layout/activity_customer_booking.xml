<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn địa điểm &amp; thời gian"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/txtSelectLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhấn để chọn địa điểm"
        android:padding="16dp"
        android:background="@android:drawable/editbox_background"
        android:drawableEnd="@android:drawable/arrow_down_float"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/txtSelectTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhấn để chọn Ngày &amp; Giờ"
        android:padding="16dp"
        android:background="@android:drawable/editbox_background"
        android:drawableEnd="@android:drawable/ic_menu_month"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnConfirmBooking"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="XÁC NHẬN"
        android:backgroundTint="#2196F3"/>
</LinearLayout>